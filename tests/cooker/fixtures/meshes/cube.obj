# Unit cube fixture for the mesh cook/load tests.
# 8 positions, 4 UVs, 6 face normals; 6 quads as 12 triangles. With per-face
# normals/UVs assimp yields 24 vertices (4 per face) and 36 indices.
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0
vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0
# back (-z)
f 1/1/1 2/2/1 3/3/1
f 1/1/1 3/3/1 4/4/1
# front (+z)
f 5/1/2 6/2/2 7/3/2
f 5/1/2 7/3/2 8/4/2
# left (-x)
f 1/1/3 4/2/3 8/3/3
f 1/1/3 8/3/3 5/4/3
# right (+x)
f 2/1/4 6/2/4 7/3/4
f 2/1/4 7/3/4 3/4/4
# bottom (-y)
f 1/1/5 5/2/5 6/3/5
f 1/1/5 6/3/5 2/4/5
# top (+y)
f 4/1/6 3/2/6 7/3/6
f 4/1/6 7/3/6 8/4/6
