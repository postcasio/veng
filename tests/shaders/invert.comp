#version 450

// Minimal compute pass for the compute-dispatch test: reads one
// storage image and writes the colour-inverted result to another. Proves
// cmd.Dispatch + the render graph's StorageRead/StorageWrite barriers for a
// graphics-write -> compute-read/write -> graphics-read chain.

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

// set 0 is reserved for the bindless registry; this set is
// bound at FirstSet = 1.
layout(set = 1, binding = 0, rgba8) uniform readonly image2D u_Source;
layout(set = 1, binding = 1, rgba8) uniform writeonly image2D u_Destination;

void main()
{
    const ivec2 coord = ivec2(gl_GlobalInvocationID.xy);
    const vec4 source = imageLoad(u_Source, coord);
    imageStore(u_Destination, coord, vec4(vec3(1.0) - source.rgb, source.a));
}
