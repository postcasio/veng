# Build-tree veng package config. Written to the engine build-dir root by export(EXPORT)
# so find_package(veng) resolves against veng/build with no install step — the co-development
# path where the engine's cmake --build refreshes the exported targets in place and the game's
# next build picks them up. Generated by a plain configure_file (not configure_package_config_file):
# the install config's package-init prefix macro walks up the install nesting depth, which is
# wrong for a config sitting at the build-dir root, so the build-tree paths are substituted here.

include(CMakeFindDependencyMacro)

# The install config gets check_required_components() from @PACKAGE_INIT@; a plain
# configure_file does not, so define the standard macro here for the shared body's call.
macro(check_required_components _NAME)
    foreach (comp ${${_NAME}_FIND_COMPONENTS})
        if (NOT ${_NAME}_${comp}_FOUND)
            if (${_NAME}_FIND_REQUIRED_${comp})
                set(${_NAME}_FOUND FALSE)
            endif ()
        endif ()
    endforeach ()
endmacro()

# veng's exported link interface names glm::glm, fmt::fmt (PUBLIC on veng), and
# libzstd_static (PUBLIC through the static assetpack). In a build tree those dependency
# targets live in scattered FetchContent build dirs, not one install prefix, so resolve
# each from the build-tree export it wrote rather than a find_dependency against a prefix.
# The paths are the FetchContent build dirs baked at generate time. Vulkan is a real system
# find_package, so it resolves the same way in every mode.
find_dependency(Vulkan)
if (NOT TARGET fmt::fmt)
    include("@FMT_BINARY_DIR@/fmt-targets.cmake")
endif ()
if (NOT TARGET glm::glm)
    include("${CMAKE_CURRENT_LIST_DIR}/deps/glm-targets.cmake")
endif ()
if (NOT TARGET libzstd_static)
    include("@zstd_BINARY_DIR@/zstdTargets.cmake")
endif ()

# The consumption mode the helper modules resolve their mode-keyed path variables against.
set(VENG_PACKAGE_MODE "BUILD_TREE")

# The helper *.cmake modules load from the live source tree, so a co-development engine-source
# edit to a helper (or to the config body) is visible to the game on the next configure.
set(VENG_CMAKE_HELPER_DIR "@CMAKE_CURRENT_SOURCE_DIR@/cmake")

# The path variables resolve to the live source tree, not an install prefix: an engine core-data
# or launcher edit is visible to the game with only a rebuild. VENG_CORE_* is the internal
# scaffolding threaded to every cook (--shader-include / --reference); the lowercase veng_CORE_*
# aliases are the consumer-facing find_package result API.
set(VENG_LAUNCHER_MAIN "@CMAKE_CURRENT_SOURCE_DIR@/engine/src/Launcher/launcher_main.cpp"
    CACHE INTERNAL "veng launcher source")
set(VENG_CORE_SHADER_DIR "@CMAKE_CURRENT_SOURCE_DIR@/engine/assets/core/shaders"
    CACHE PATH "Engine core shader directory added to every cook's Slang search path")
set(VENG_CORE_PACK_JSON "@CMAKE_CURRENT_SOURCE_DIR@/engine/assets/core/core.vengpack.json"
    CACHE FILEPATH "Engine core pack source manifest referenced by a downstream cook")
set(veng_CORE_SHADER_DIR "${VENG_CORE_SHADER_DIR}")
set(veng_CORE_PACK_JSON "${VENG_CORE_PACK_JSON}")

include("${CMAKE_CURRENT_LIST_DIR}/veng-config-body.cmake")
