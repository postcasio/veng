#!/usr/bin/env bash
# Pre-commit gate over the staged C/C++ changes. Stage 1 (clang-format) checks the
# touched lines; stage 2 (clang-tidy) lints each staged translation unit against the
# allowlist. Each skips cleanly when its tooling is absent, so the hook never blocks
# a clone that lacks the tools.
set -euo pipefail

# --- Stage 1: clang-format (repo-root .clang-format) -------------------------
# Format-check only the touched lines via git clang-format --staged.
if command -v clang-format >/dev/null 2>&1 && command -v git-clang-format >/dev/null 2>&1; then
    diff=$(git clang-format --staged --diff --extensions h,hpp,cpp,cc 2>/dev/null || true)
    case "$diff" in
        "" | "no modified files to format" | "clang-format did not modify any files")
            ;;
        *)
            echo "pre-commit: staged C/C++ changes are not clang-format clean." >&2
            echo "Fix with:  git clang-format --staged   then re-stage the files and commit." >&2
            echo "------------------------------------------------------------------" >&2
            printf '%s\n' "$diff" >&2
            exit 1
            ;;
    esac
else
    echo "pre-commit: clang-format / git-clang-format not found, skipping format check." >&2
fi

# --- Stage 2: clang-tidy (repo-root .clang-tidy) -----------------------------
# Lint each staged .cpp/.cc against the allowlist. The tree is kept clean against
# .clang-tidy, so any finding on a touched TU is a real regression — no changed-line
# diffing needed. A changed header is checked transitively (a staged TU that includes
# it reports its findings via HeaderFilterRegex); a header-only commit drives no TU,
# so use -DVENG_ENABLE_CLANG_TIDY=ON or CI for those. Needs a compile DB
# (compile_commands.json, exported unconditionally into build/). Skips cleanly when
# clang-tidy or a DB is absent, or when nothing relevant is staged.
tidy_db=""
for d in build build-debug cmake-build-debug; do
    if [ -f "$d/compile_commands.json" ]; then
        tidy_db="$d"
        break
    fi
done

staged_tus=$(git diff --cached --name-only --diff-filter=ACM -- '*.cpp' '*.cc')

if command -v clang-tidy >/dev/null 2>&1 && [ -n "$tidy_db" ] && [ -n "$staged_tus" ]; then
    # The compile DB carries AppleClang's flags, which omit the implicit macOS SDK
    # and Vulkan include paths LLVM's clang-tidy needs. Supply them by env so no
    # per-file --extra-arg plumbing is required; both are no-ops off macOS.
    sdk=$(xcrun --show-sdk-path 2>/dev/null || true)
    [ -n "$sdk" ] && export SDKROOT="$sdk"
    vk=$(grep -m1 '^Vulkan_INCLUDE_DIR:' "$tidy_db/CMakeCache.txt" 2>/dev/null | cut -d= -f2 || true)
    [ -n "$vk" ] && export CPATH="${vk}${CPATH:+:$CPATH}"

    tidy_out=$(printf '%s\n' "$staged_tus" | tr '\n' '\0' \
        | xargs -0 clang-tidy -p "$tidy_db" --quiet 2>/dev/null || true)
    if printf '%s\n' "$tidy_out" | grep -qE ': (warning|error):'; then
        echo "pre-commit: clang-tidy flagged staged C/C++ changes." >&2
        echo "Fix the findings below or justify with NOLINT, then re-stage and commit." >&2
        echo "------------------------------------------------------------------" >&2
        printf '%s\n' "$tidy_out" | grep -E ': (warning|error):' >&2
        exit 1
    fi
else
    echo "pre-commit: clang-tidy or a compile DB not found (or no staged .cpp/.cc), skipping tidy check." >&2
fi

exit 0
